<ui:FluentWindow x:Class="Scheduler.Ui.AddJobWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="進階排程編輯器" Height="600" Width="700"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica" WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="進階排程編輯器" />
        
        <TabControl Grid.Row="1" Margin="20,0,20,10">
            <!-- 1. 一般 -->
            <TabItem Header="一般">
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Margin="0,10,0,0" Padding="20">
                    <StackPanel>
                    <TextBlock Text="名稱(M):" FontWeight="Bold"/>
                    <TextBox Text="{Binding JobName, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsCreationMode}" Margin="0,5,0,15"/>
                    
                    <TextBlock Text="群組(G):" FontWeight="Bold"/>
                    <TextBox Text="{Binding JobGroup, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsCreationMode}" Margin="0,5,0,15"/>
                    
                    <TextBlock Text="描述(D):" FontWeight="Bold"/>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,15"/>

                    <CheckBox Content="隱藏目標程式視窗(I) (僅限命令列程式)" IsChecked="{Binding IsHidden}" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </TabItem>
            
            <!-- 2. 觸發程序 -->
            <TabItem Header="觸發程序">
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Margin="0,10,0,0" Padding="20">
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="當您建立工作時，您可以指定將觸發工作的條件。" Margin="0,0,0,10"/>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Triggers}" SelectedItem="{Binding SelectedTrigger}" 
                              AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" Margin="0,0,0,10"
                              BorderBrush="#CCCCCC" BorderThickness="1" Background="White">
                        <DataGrid.InputBindings>
                            <MouseBinding Gesture="LeftDoubleClick" Command="{Binding EditTriggerCommand}"/>
                        </DataGrid.InputBindings>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="觸發程序" Binding="{Binding TriggerType, TargetNullValue='僅一次/重複'}" Width="120"/>
                            <DataGridTextColumn Header="詳細資料" Binding="{Binding HumanDescription}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Button Content="新增(N)..." Command="{Binding AddTriggerCommand}" Width="80" Margin="0,0,10,0"/>
                        <Button Content="編輯(E)..." Command="{Binding EditTriggerCommand}" Width="80" Margin="0,0,10,0"/>
                        <Button Content="刪除(D)" Command="{Binding DeleteTriggerCommand}" Width="80"/>
                    </StackPanel>
                    </Grid>
                </Border>
            </TabItem>
            
            <!-- 3. 動作 -->
            <TabItem Header="動作">
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Margin="0,10,0,0" Padding="20">
                    <StackPanel>
                    <TextBlock Text="執行檔路徑 (例如: cmd.exe 或 C:\script.bat)" FontWeight="Bold"/>
                    <TextBox Text="{Binding FileName, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15"/>
                    
                    <TextBlock Text="新增引數 (例如: /c echo Hello)" FontWeight="Bold"/>
                    <TextBox Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15"/>
                    
                    <TextBlock Text="開始於 (選填工作目錄)" FontWeight="Bold"/>
                    <TextBox Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,15"/>
                    </StackPanel>
                </Border>
            </TabItem>
            
            <!-- 4. 設定 -->
            <TabItem Header="設定">
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Margin="0,10,0,0" Padding="20">
                    <StackPanel>
                    <TextBlock Text="指定影響工作行為的其他設定。" Margin="0,0,0,15"/>
                    <CheckBox Content="在錯過指定的啟動後盡快執行工作(S)" IsChecked="{Binding MisfireActionFireAndProceed}" Margin="0,0,0,15" FontSize="14"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <CheckBox Content="如果工作執行時間大於以下值即停止(K): " IsChecked="{Binding HasMaxRunTime}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                        <TextBox Text="{Binding MaxRunTimeValue, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding HasMaxRunTime}" Width="50" Margin="0,0,10,0"/>
                        <ComboBox SelectedIndex="{Binding MaxRunTimeUnitIndex}" IsEnabled="{Binding HasMaxRunTime}" Width="80">
                            <ComboBoxItem Content="分鐘"/>
                            <ComboBoxItem Content="小時"/>
                            <ComboBoxItem Content="天"/>
                        </ComboBox>
                    </StackPanel>
                    
                    <TextBlock Text="如果工作已經在執行中，下列規則將會套用(N):" Margin="0,10,0,5" FontSize="14"/>
                    <ComboBox ItemsSource="{Binding ConcurrencyOptions}" SelectedItem="{Binding SelectedConcurrency}" Width="250" HorizontalAlignment="Left" Margin="0,0,0,15" FontSize="14"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 5. 歷程記錄 -->
            <TabItem Header="歷程記錄">
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Margin="0,10,0,0" Padding="10">
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Margin="0,0,0,5" Orientation="Horizontal">
                        <TextBlock Text="📁" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="Gray"/>
                        <TextBlock Text="{Binding Logs.Count, StringFormat=事件數目: \{0\}}" VerticalAlignment="Center" FontSize="14"/>
                    </StackPanel>
                    
                    <DataGrid Grid.Row="1" x:Name="HistoryLogsGrid" ItemsSource="{Binding Logs}" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                              BorderBrush="#CCCCCC" BorderThickness="1" Background="White" RowHeight="26" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Resources>
                            <Style x:Key="CellTextStyle" TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                <Setter Property="Margin" Value="10,0,10,0"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent" />
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E3F2FD" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="等級" Binding="{Binding LevelIcon}" Width="80" ElementStyle="{StaticResource CellTextStyle}"/>
                            <DataGridTextColumn Header="日期和時間" Binding="{Binding FireTime}" Width="190" ElementStyle="{StaticResource CellTextStyle}"/>
                            <DataGridTextColumn Header="事件識別碼" Binding="{Binding EventId}" Width="90" ElementStyle="{StaticResource CellTextStyle}"/>
                            <DataGridTextColumn Header="工作類別" Binding="{Binding Category}" Width="320" ElementStyle="{StaticResource CellTextStyle}"/>
                            <DataGridTextColumn Header="操作代碼" Binding="{Binding OpCode}" Width="80" ElementStyle="{StaticResource CellTextStyle}"/>
                            <DataGridTextColumn Header="相互關聯識別碼" Binding="{Binding CorrelationId}" Width="*" Foreground="Gray" ElementStyle="{StaticResource CellTextStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="#E0E0E0" Margin="0,5"/>

                    <GroupBox Grid.Row="3" Header="{Binding SelectedItem.EventId, ElementName=HistoryLogsGrid, StringFormat='事件 \{0\}，TaskScheduler', TargetNullValue='(未選取事件)'}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="5">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedItem.Description, ElementName=HistoryLogsGrid}" TextWrapping="Wrap" Margin="10,10,10,20" FontSize="14"/>
                                
                                <StackPanel Visibility="{Binding SelectedItem.ErrorMessageVisibility, ElementName=HistoryLogsGrid, FallbackValue=Collapsed}">
                                    <TextBlock Text="[詳細系統日誌 / 原生錯誤內容]" Foreground="Gray" FontWeight="Bold" Margin="10,0,10,5"/>
                                    <TextBlock Text="{Binding SelectedItem.Original.ErrorMessage, ElementName=HistoryLogsGrid}" TextWrapping="Wrap" Margin="10,0,10,10" FontFamily="Consolas" Foreground="DarkRed"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </GroupBox>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,20,20">
            <ui:Button Appearance="Primary" Content="儲存設定" Command="{Binding CreateOrUpdateCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Width="100" Margin="0,0,10,0"/>
            <ui:Button Content="取消" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
