<UserControl x:Class="Scheduler.Ui.Controls.TimePickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border BorderBrush="#ABADB3" BorderThickness="1" Background="White" MinHeight="32" CornerRadius="4">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="17" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="AmPmText" Grid.Column="1" Text="上午" Margin="6,0,4,0" VerticalAlignment="Center" MouseLeftButtonDown="AmPmText_MouseDown" Cursor="Hand" ToolTip="點擊切換" />
            
            <TextBox x:Name="HourText" Grid.Column="2" MaxLength="2" Text="12" Width="32" BorderThickness="0" Background="Transparent" Padding="0" Margin="0,1,0,0" VerticalContentAlignment="Center" TextAlignment="Center" VerticalAlignment="Center" PreviewTextInput="NumberValidation" GotFocus="TimeSegment_GotFocus" LostFocus="TimeSegment_LostFocus" />
            
            <TextBlock Grid.Column="3" Text=":" VerticalAlignment="Center" Margin="0" />
            
            <TextBox x:Name="MinuteText" Grid.Column="4" MaxLength="2" Text="00" Width="32" BorderThickness="0" Background="Transparent" Padding="0" Margin="0,1,0,0" VerticalContentAlignment="Center" TextAlignment="Center" VerticalAlignment="Center" PreviewTextInput="NumberValidation" GotFocus="TimeSegment_GotFocus" LostFocus="TimeSegment_LostFocus" />
            
            <TextBlock Grid.Column="5" Text=":" VerticalAlignment="Center" Margin="0" />
            
            <TextBox x:Name="SecondText" Grid.Column="6" MaxLength="2" Text="00" Width="32" BorderThickness="0" Background="Transparent" Padding="0" Margin="0,1,0,0" VerticalContentAlignment="Center" TextAlignment="Center" VerticalAlignment="Center" PreviewTextInput="NumberValidation" GotFocus="TimeSegment_GotFocus" LostFocus="TimeSegment_LostFocus" />

            <Grid Grid.Column="7" Background="#FFF0F0F0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <RepeatButton x:Name="UpButton" Grid.Row="0" Click="UpButton_Click" Focusable="False" Padding="0" Margin="0" Delay="300" Interval="100">
                    <Path Data="M 0,3 L 3,0 L 6,3 Z" Fill="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </RepeatButton>
                <RepeatButton x:Name="DownButton" Grid.Row="1" Click="DownButton_Click" Focusable="False" Padding="0" Margin="0" Delay="300" Interval="100">
                    <Path Data="M 0,0 L 3,3 L 6,0 Z" Fill="Black" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </RepeatButton>
            </Grid>
        </Grid>
    </Border>
</UserControl>
