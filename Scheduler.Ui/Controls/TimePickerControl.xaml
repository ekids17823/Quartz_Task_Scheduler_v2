<UserControl x:Class="Scheduler.Ui.Controls.TimePickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border BorderBrush="#ABADB3" BorderThickness="1" Background="White" Height="22">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="17" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TimeTextBox" Grid.Column="0" BorderThickness="0" VerticalAlignment="Center" Margin="2,0" 
                     Text="上午 12:00:00" PreviewKeyDown="TimeTextBox_PreviewKeyDown" LostFocus="TimeTextBox_LostFocus" />
            <Grid Grid.Column="1" Background="#FFF0F0F0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <!-- Windows 10 style up/down arrows -->
                <RepeatButton x:Name="UpButton" Grid.Row="0" Click="UpButton_Click" Focusable="False" Padding="0" Margin="0" Delay="300" Interval="100">
                    <Path Data="M 0,3 L 3,0 L 6,3 Z" Fill="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </RepeatButton>
                <RepeatButton x:Name="DownButton" Grid.Row="1" Click="DownButton_Click" Focusable="False" Padding="0" Margin="0" Delay="300" Interval="100">
                    <Path Data="M 0,0 L 3,3 L 6,0 Z" Fill="Black" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </RepeatButton>
            </Grid>
        </Grid>
    </Border>
</UserControl>
