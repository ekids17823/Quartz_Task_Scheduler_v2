<ui:FluentWindow x:Class="Scheduler.Ui.EditTriggerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Scheduler.Ui.Controls"
        Title="新增/編輯觸發程序" Height="620" Width="750"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica" WindowCornerPreference="Round">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="新增/編輯觸發程序" />
        
        <Grid Grid.Row="1" Margin="20,0,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="開始工作(G): " VerticalAlignment="Center"/>
            <ComboBox SelectedIndex="0" Width="250" Margin="10,0,0,0">
                <ComboBoxItem Content="依排程執行"/>
            </ComboBox>
        </StackPanel>

        <!-- 設定區塊 (左右分欄) -->
        <GroupBox Grid.Row="1" Header="設定" Margin="0,0,0,15">
            <Grid VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <!-- 左側：單選按鈕 -->
                <StackPanel Grid.Column="0" Margin="10">
                    <TextBlock Text="開始工作(G):" Margin="0,0,0,10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <RadioButton Content="僅一次(N)" IsChecked="{Binding IsOneTime}" Margin="0,0,0,15" FontSize="14"/>
                    <RadioButton Content="定期循環(I)" IsChecked="{Binding IsInterval}" Margin="0,0,0,15" FontSize="14"/>
                    <RadioButton Content="每天(D)" IsChecked="{Binding IsDaily}" Margin="0,0,0,15" FontSize="14"/>
                    <RadioButton Content="每週(W)" IsChecked="{Binding IsWeekly}" Margin="0,0,0,15" FontSize="14"/>
                    <RadioButton Content="每月(M)" IsChecked="{Binding IsMonthly}" Margin="0,0,0,15" FontSize="14"/>
                </StackPanel>
                
                <!-- 分隔線 -->
                <Rectangle Grid.Column="1" Fill="#E0E0E0" Margin="0,10"/>
                
                <!-- 右側：動態面板 -->
                <StackPanel Grid.Column="2" Margin="15,10,10,10">
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="開始(S):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <DatePicker SelectedDate="{Binding StartAtDate}" VerticalAlignment="Center" Width="150" Margin="0,0,10,0"/>
                        <local:TimePickerControl Time="{Binding StartAtTimeString, Mode=TwoWay}" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Grid>
                        <!-- 僅一次面板(保留空白) -->
                        
                        <!-- 定期循環面板 -->
                        <StackPanel Visibility="{Binding IsInterval, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal" Height="45" Margin="0,0,0,0">
                                <TextBlock Text="每隔(C): " VerticalAlignment="Center" Width="60"/>
                                <TextBox Text="{Binding IntervalValue}" Width="50" Margin="0,0,10,0"/>
                                <ComboBox SelectedIndex="{Binding IntervalUnitIndex}" Width="80">
                                    <ComboBoxItem Content="分鐘"/>
                                    <ComboBoxItem Content="小時"/>
                                    <ComboBoxItem Content="天"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- 每天 UI -->
                        <StackPanel Visibility="{Binding IsDaily, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal" Height="45" Margin="0,0,0,0">
                                <TextBlock Text="每隔(C): " VerticalAlignment="Center" Width="60"/>
                                <TextBox Text="{Binding DailyInterval}" Width="50" Margin="0,0,10,0"/>
                                <TextBlock Text="天" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- 每週 UI -->
                        <StackPanel Visibility="{Binding IsWeekly, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal" Height="45" Margin="0,0,0,10">
                                <TextBlock Text="每隔(C): " VerticalAlignment="Center" Width="60"/>
                                <TextBox Text="{Binding WeeklyInterval}" Width="50" Margin="0,0,10,0"/>
                                <TextBlock Text="星期 的:" VerticalAlignment="Center"/>
                            </StackPanel>
                            <WrapPanel>
                                <CheckBox Content="星期日(U)" IsChecked="{Binding WeekSun}" Width="100" Margin="0,0,0,10"/>
                                <CheckBox Content="星期一(A)" IsChecked="{Binding WeekMon}" Width="100" Margin="0,0,0,10"/>
                                <CheckBox Content="星期二(T)" IsChecked="{Binding WeekTue}" Width="100" Margin="0,0,0,10"/>
                                <CheckBox Content="星期三(E)" IsChecked="{Binding WeekWed}" Width="100" Margin="0,0,0,10"/>
                                <CheckBox Content="星期四(H)" IsChecked="{Binding WeekThu}" Width="100" Margin="0,0,0,10"/>
                                <CheckBox Content="星期五(F)" IsChecked="{Binding WeekFri}" Width="100" Margin="0,0,0,10"/>
                                <CheckBox Content="星期六(R)" IsChecked="{Binding WeekSat}" Width="100" Margin="0,0,0,10"/>
                            </WrapPanel>
                        </StackPanel>
                        
                        <!-- 每月 UI (UI Mock) -->
                        <StackPanel Visibility="{Binding IsMonthly, Converter={StaticResource BoolToVis}}">
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="45"/>
                                    <RowDefinition Height="45"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Text="月份(H):" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                                <ToggleButton x:Name="MonthsPopupToggle" Content="{Binding MonthsSummary}" Grid.Row="0" Grid.Column="1" Width="250" HorizontalAlignment="Left" HorizontalContentAlignment="Left" />
                                <Popup IsOpen="{Binding IsChecked, ElementName=MonthsPopupToggle}" StaysOpen="False" PlacementTarget="{Binding ElementName=MonthsPopupToggle}">
                                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="10">
                                        <StackPanel Width="230">
                                            <CheckBox Content="&lt;選取每個月&gt;" IsChecked="{Binding IsAllMonthsSelected}" Command="{Binding ToggleAllMonthsCommand}" Margin="5,0,0,10" FontWeight="SemiBold" />
                                            <ItemsControl ItemsSource="{Binding MonthsList}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="2" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Content="{Binding Display}" IsChecked="{Binding IsSelected}" Margin="5,0,0,5" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                                
                                <RadioButton Content="天(A):" IsChecked="{Binding IsMonthlyModeDays}" GroupName="MonthlyMode" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                                <ToggleButton x:Name="DaysPopupToggle" Content="{Binding MonthDaysSummary}" Grid.Row="1" Grid.Column="1" Width="250" HorizontalAlignment="Left" HorizontalContentAlignment="Left" IsEnabled="{Binding IsMonthlyModeDays}" />
                                <Popup IsOpen="{Binding IsChecked, ElementName=DaysPopupToggle}" StaysOpen="False" PlacementTarget="{Binding ElementName=DaysPopupToggle}">
                                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="10">
                                        <ItemsControl ItemsSource="{Binding MonthDaysList}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="5" Width="260" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Display}" IsChecked="{Binding IsSelected}" Margin="0,0,0,5" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </Popup>
                                
                                <RadioButton Content="於(O):" IsChecked="{Binding IsMonthlyModeOn}" GroupName="MonthlyMode" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" IsEnabled="{Binding IsMonthlyModeOn}">
                                    <ComboBox SelectedIndex="{Binding MonthlyOnSeqIndex}" Width="110" Margin="0,0,10,0">
                                        <ComboBoxItem Content="第一個"/>
                                        <ComboBoxItem Content="第二個"/>
                                        <ComboBoxItem Content="第三個"/>
                                        <ComboBoxItem Content="第四個"/>
                                        <ComboBoxItem Content="最後一個"/>
                                    </ComboBox>
                                    <ComboBox SelectedIndex="{Binding MonthlyOnDowIndex}" Width="100">
                                        <ComboBoxItem Content="星期日"/>
                                        <ComboBoxItem Content="星期一"/>
                                        <ComboBoxItem Content="星期二"/>
                                        <ComboBoxItem Content="星期三"/>
                                        <ComboBoxItem Content="星期四"/>
                                        <ComboBoxItem Content="星期五"/>
                                        <ComboBoxItem Content="星期六"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 進階設定區塊 -->
        <GroupBox Grid.Row="2" Header="進階設定" Padding="10" IsEnabled="{Binding IsNotInterval}">
            <StackPanel>
                <!-- 每隔多久重複 -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                    <CheckBox Content="重複工作每隔(P): " IsChecked="{Binding IsRepeating}" VerticalAlignment="Center" Width="180"/>
                    <TextBox Text="{Binding RepeatInterval, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsRepeating}" Width="50" Margin="0,0,5,0"/>
                    <ComboBox SelectedIndex="{Binding RepeatIntervalUnitIndex}" IsEnabled="{Binding IsRepeating}" Width="80">
                        <ComboBoxItem Content="分鐘"/>
                        <ComboBoxItem Content="小時"/>
                    </ComboBox>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <CheckBox Content="持續時間(D): " IsChecked="{Binding HasRepeatDuration}" IsEnabled="{Binding IsRepeating}" VerticalAlignment="Center" Width="180" Margin="20,0,0,0"/>
                    <TextBox Text="{Binding RepeatDuration, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding HasRepeatDuration}" Width="50" Margin="0,0,5,0"/>
                    <ComboBox SelectedIndex="{Binding RepeatDurationUnitIndex}" IsEnabled="{Binding HasRepeatDuration}" Width="80">
                        <ComboBoxItem Content="分鐘"/>
                        <ComboBoxItem Content="小時"/>
                        <ComboBoxItem Content="天"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- 按鈕 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Appearance="Primary" Content="儲存設定" Command="{Binding SaveCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Width="100" Margin="0,0,10,0"/>
            <ui:Button Content="取消" Click="Cancel_Click" Width="80"/>
        </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
