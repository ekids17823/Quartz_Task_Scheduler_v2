<Window x:Class="Scheduler.Ui.EditTriggerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Scheduler.Ui.Controls"
        Title="新增/編輯觸發程序" Height="500" Width="680"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="開始工作(G): " VerticalAlignment="Center"/>
            <ComboBox SelectedIndex="0" Width="250" Margin="10,0,0,0">
                <ComboBoxItem Content="依排程執行"/>
            </ComboBox>
        </StackPanel>

        <!-- 設定區塊 (左右分欄) -->
        <GroupBox Grid.Row="1" Header="設定" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <!-- 左側：單選按鈕 -->
                <StackPanel Grid.Column="0" Margin="10">
                    <RadioButton Content="僅一次(N)" IsChecked="{Binding IsOneTime}" Margin="0,5,0,15" FontSize="14" FontWeight="SemiBold"/>
                    <RadioButton Content="每天(D)" IsChecked="{Binding IsDaily}" Margin="0,0,0,15" FontSize="14"/>
                    <RadioButton Content="每週(W)" IsChecked="{Binding IsWeekly}" Margin="0,0,0,15" FontSize="14"/>
                    <RadioButton Content="每月(M)" IsChecked="{Binding IsMonthly}" Margin="0,0,0,15" FontSize="14"/>
                </StackPanel>
                
                <!-- 分隔線 -->
                <Rectangle Grid.Column="1" Fill="#E0E0E0" Margin="0,10"/>
                
                <!-- 右側：動態面板 -->
                <StackPanel Grid.Column="2" Margin="15,10,10,10">
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="開始(S):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <DatePicker SelectedDate="{Binding StartAtDate}" Width="110" Margin="0,0,5,0"/>
                        <local:TimePickerControl Time="{Binding StartAtTimeString, Mode=TwoWay}" Width="100"/>
                        <CheckBox Content="同步處理不同時區(Z)" Margin="15,0,0,0" VerticalAlignment="Center" IsEnabled="False"/>
                    </StackPanel>
                    
                    <Grid>
                        <!-- 僅一次面板(保留空白) -->
                        
                        <!-- 每天 UI -->
                        <StackPanel Visibility="{Binding IsDaily, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                <TextBlock Text="每隔(C): " VerticalAlignment="Center" Width="60"/>
                                <TextBox Text="{Binding DailyInterval}" Width="50" Margin="0,0,10,0"/>
                                <TextBlock Text="天" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- 每週 UI -->
                        <StackPanel Visibility="{Binding IsWeekly, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal" Margin="0,15,0,15">
                                <TextBlock Text="每隔(C): " VerticalAlignment="Center" Width="60"/>
                                <TextBox Text="{Binding WeeklyInterval}" Width="50" Margin="0,0,10,0"/>
                                <TextBlock Text="星期 的:" VerticalAlignment="Center"/>
                            </StackPanel>
                            <WrapPanel>
                                <CheckBox Content="星期日(U)" IsChecked="{Binding WeekSun}" Width="100" Margin="0,0,0,10"/>
                                <CheckBox Content="星期一(A)" IsChecked="{Binding WeekMon}" Width="100" Margin="0,0,0,10"/>
                                <CheckBox Content="星期二(T)" IsChecked="{Binding WeekTue}" Width="100" Margin="0,0,0,10"/>
                                <CheckBox Content="星期三(E)" IsChecked="{Binding WeekWed}" Width="100" Margin="0,0,0,10"/>
                                <CheckBox Content="星期四(H)" IsChecked="{Binding WeekThu}" Width="100" Margin="0,0,0,10"/>
                                <CheckBox Content="星期五(F)" IsChecked="{Binding WeekFri}" Width="100"/>
                                <CheckBox Content="星期六(R)" IsChecked="{Binding WeekSat}" Width="100"/>
                            </WrapPanel>
                        </StackPanel>
                        
                        <!-- 每月 UI (UI Mock) -->
                        <StackPanel Visibility="{Binding IsMonthly, Converter={StaticResource BoolToVis}}">
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Text="月份(H):" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,15"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" SelectedIndex="0" Margin="0,0,0,15" Width="250" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="所有月份"/>
                                </ComboBox>
                                
                                <RadioButton Content="天(A):" IsChecked="True" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,15"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" SelectedIndex="0" Margin="0,0,0,15" Width="250" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="第一天"/>
                                </ComboBox>
                                
                                <RadioButton Content="於(O):" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                    <ComboBox Width="100" SelectedIndex="0" Margin="0,0,10,0">
                                        <ComboBoxItem Content="第一個"/>
                                    </ComboBox>
                                    <ComboBox Width="140" SelectedIndex="0">
                                        <ComboBoxItem Content="週一"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- 進階設定區塊 -->
        <GroupBox Grid.Row="2" Header="進階設定" Padding="10">
            <StackPanel>
                <!-- 每隔多久重複 -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                    <CheckBox Content="重複工作每隔(P): " IsChecked="{Binding IsRepeating}" VerticalAlignment="Center" Width="180"/>
                    <TextBox Text="{Binding RepeatIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsRepeating}" Width="50" Margin="0,0,5,0"/>
                    <TextBlock Text="分鐘" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- 按鈕 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="確定" Command="{Binding SaveCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Width="80" Margin="0,0,10,0"/>
            <Button Content="取消" Click="Cancel_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
