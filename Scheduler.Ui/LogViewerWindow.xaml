<ui:FluentWindow x:Class="Scheduler.Ui.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="排程執行紀錄" Height="600" Width="900"
        WindowStartupLocation="CenterOwner" Loaded="Window_Loaded"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica" WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="排程執行紀錄" />
        
        <Grid Grid.Row="1" Margin="20,0,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Margin="0,0,0,10" Orientation="Horizontal">
            <TextBlock Text="📁" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="Gray"/>
            <TextBlock x:Name="LogCountText" VerticalAlignment="Center" FontSize="14"/>
        </StackPanel>
        
        <DataGrid Grid.Row="1" x:Name="LogsGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                  RowHeight="26" GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="0" Background="Transparent">
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Resources>
                <Style x:Key="CellTextStyle" TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="HorizontalAlignment" Value="Left"/>
                    <Setter Property="Margin" Value="10,0,10,0"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#E3F2FD" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="等級" Binding="{Binding LevelIcon}" Width="80" ElementStyle="{StaticResource CellTextStyle}"/>
                <DataGridTextColumn Header="日期和時間" Binding="{Binding FireTime}" Width="190" ElementStyle="{StaticResource CellTextStyle}"/>
                <DataGridTextColumn Header="事件識別碼" Binding="{Binding EventId}" Width="60" ElementStyle="{StaticResource CellTextStyle}"/>
                <DataGridTextColumn Header="工作類別" Binding="{Binding Category}" Width="320" ElementStyle="{StaticResource CellTextStyle}"/>
                <DataGridTextColumn Header="操作代碼" Binding="{Binding OpCode}" Width="80" ElementStyle="{StaticResource CellTextStyle}"/>
                <DataGridTextColumn Header="相互關聯識別碼" Binding="{Binding CorrelationId}" Width="140" Foreground="Gray" ElementStyle="{StaticResource CellTextStyle}"/>
            </DataGrid.Columns>
        </DataGrid>

        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="#E0E0E0" Margin="0,5"/>

        <GroupBox Grid.Row="3" Header="{Binding SelectedItem.EventId, ElementName=LogsGrid, StringFormat='事件 \{0\}，TaskScheduler', TargetNullValue='(未選取事件)'}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="5">
                <StackPanel>
                    <TextBlock Text="{Binding SelectedItem.Description, ElementName=LogsGrid}" TextWrapping="Wrap" Margin="10,10,10,20" FontSize="14"/>
                    
                    <StackPanel Visibility="{Binding SelectedItem.ErrorMessageVisibility, ElementName=LogsGrid, FallbackValue=Collapsed}">
                        <TextBlock Text="[詳細系統日誌 / 原生錯誤內容]" Foreground="Gray" FontWeight="Bold" Margin="10,0,10,5"/>
                        <TextBlock Text="{Binding SelectedItem.Original.ErrorMessage, ElementName=LogsGrid}" TextWrapping="Wrap" Margin="10,0,10,10" FontFamily="Consolas" Foreground="DarkRed"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </GroupBox>
        </Grid>
    </Grid>
</ui:FluentWindow>
