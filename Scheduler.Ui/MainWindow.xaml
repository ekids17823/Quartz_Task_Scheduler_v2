<ui:FluentWindow x:Class="Scheduler.Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:Scheduler.Ui.ViewModels"
        Title="Quartz Task Scheduler v2" Height="768" Width="1400"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True" WindowState="Maximized"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">

    <ui:FluentWindow.DataContext>
        <vm:MainViewModel />
    </ui:FluentWindow.DataContext>

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>

    <Grid VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- The TitleBar -->
        <ui:TitleBar Grid.Row="0" Title="Quartz Task Scheduler v2" Icon="pack://application:,,,/app_icon.ico" />

        <!-- Main Layout -->
        <Grid Grid.Row="1" Margin="20,0,20,20" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Page Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <ui:TextBlock FontTypography="Title" Text="排程總覽" Margin="0,0,0,5"/>
                <ui:TextBlock FontTypography="Body" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="檢視並管理系統中所有的在地與預定背景任務。"/>
            </StackPanel>

            <!-- ToolBar -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                <ui:Button Appearance="Primary" Icon="{ui:SymbolIcon Add24}" Content="新增排程" Command="{Binding OpenAddJobCommand}" Margin="0,0,10,0"/>
                <ui:Button Icon="{ui:SymbolIcon ArrowClockwise24}" Content="重新整理" Command="{Binding LoadJobsCommand}" Margin="0,0,10,0"/>
                
                <ui:Button Icon="{ui:SymbolIcon Play24}" Content="執行" Command="{Binding RunJobCommand}" Margin="0,0,10,0"/>
                <ui:Button Icon="{ui:SymbolIcon Stop24}" Content="結束" Command="{Binding EndJobCommand}" Margin="0,0,10,0"/>
                <ui:Button Icon="{ui:SymbolIcon Pause24}" Content="停用" Command="{Binding DisableJobCommand}" Margin="0,0,10,0"/>
                <ui:Button Icon="{ui:SymbolIcon PlayCircle24}" Content="啟用" Command="{Binding EnableJobCommand}" Margin="0,0,10,0"/>
                <ui:Button Icon="{ui:SymbolIcon Settings24}" Content="內容" Command="{Binding EditJobCommand}" Margin="0,0,10,0"/>
                <ui:Button Icon="{ui:SymbolIcon DocumentText24}" Content="檢視紀錄" Command="{Binding ViewLogsCommand}" Margin="0,0,10,0"/>
                <ui:Button Appearance="Danger" Icon="{ui:SymbolIcon Delete24}" Content="刪除" Command="{Binding DeleteJobCommand}" />
            </StackPanel>

            <!-- Grid Content -->
            <Border Grid.Row="2" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="0">
                <DataGrid ItemsSource="{Binding Jobs}" SelectedItem="{Binding SelectedJob}" VerticalAlignment="Stretch"
                          AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                          RowHeight="35" FontSize="14"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="0" Background="Transparent">
                    
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="執行(R)" Command="{Binding PlacementTarget.Tag.RunJobCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                  Visibility="{Binding PlacementTarget.DataContext.IsActiveState, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}" />
                                        <MenuItem Header="結束(E)" Command="{Binding PlacementTarget.Tag.EndJobCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                  Visibility="{Binding PlacementTarget.DataContext.IsActiveState, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}" />
                                        <MenuItem Header="停用(I)" Command="{Binding PlacementTarget.Tag.DisableJobCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                  Visibility="{Binding PlacementTarget.DataContext.IsActiveState, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}" />
                                        <MenuItem Header="啟用(N)" Command="{Binding PlacementTarget.Tag.EnableJobCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                  Visibility="{Binding PlacementTarget.DataContext.IsDisabledState, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}" />
                                        <MenuItem Header="匯出(X)..." IsEnabled="False" />
                                        <MenuItem Header="內容(P)" Command="{Binding PlacementTarget.Tag.EditJobCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem Header="刪除(D)" Command="{Binding PlacementTarget.Tag.DeleteJobCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                            <EventSetter Event="MouseDoubleClick" Handler="DataGridRow_MouseDoubleClick" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#E3F2FD" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="名稱" Binding="{Binding JobName}" Width="150"/>
                        <DataGridTextColumn Header="狀態" Binding="{Binding State}" Width="80"/>
                        <DataGridTextColumn Header="觸發程序" Binding="{Binding TriggerDescription}" Width="350"/>
                        <DataGridTextColumn Header="下次執行時間" Binding="{Binding NextFireTime, StringFormat=\{0:yyyy/MM/dd tt hh:mm:ss\}, TargetNullValue='無'}" Width="180"/>
                        <DataGridTextColumn Header="上次執行時間" Binding="{Binding PreviousFireTime, StringFormat=\{0:yyyy/MM/dd tt hh:mm:ss\}, TargetNullValue='無'}" Width="180"/>
                        <DataGridTextColumn Header="上次執行結果" Binding="{Binding LastRunResult}" Width="200" />
                        <DataGridTextColumn Header="作者" Binding="{Binding Author}" Width="200" />
                        <DataGridTextColumn Header="建立日期" Binding="{Binding CreationDate, StringFormat=\{0:yyyy/MM/dd tt hh:mm:ss\}}" Width="180" />
                        <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
