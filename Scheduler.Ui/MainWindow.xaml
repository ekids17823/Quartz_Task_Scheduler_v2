<Window x:Class="Scheduler.Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Scheduler.Ui"
        xmlns:vm="clr-namespace:Scheduler.Ui.ViewModels"
        mc:Ignorable="d"
        Title="Quartz Task Scheduler v2" Height="600" Width="950"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ToolBar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="新增排程" Command="{Binding OpenAddJobCommand}" Width="80" Margin="0,0,10,0" Background="#FFDDFFA7"/>
            <Button Content="重新整理" Command="{Binding LoadJobsCommand}" Width="80" Margin="0,0,10,0"/>
            <!-- Windows 工作排程器操作風格功能 -->
            <Button Content="執行" Command="{Binding RunJobCommand}" Width="60" Margin="0,0,10,0"/>
            <Button Content="結束" Command="{Binding EndJobCommand}" Width="60" Margin="0,0,10,0"/>
            <Button Content="停用" Command="{Binding DisableJobCommand}" Width="60" Margin="0,0,10,0"/>
            <Button Content="啟用" Command="{Binding EnableJobCommand}" Width="60" Margin="0,0,10,0"/>
            <Button Content="內容" Command="{Binding EditJobCommand}" Width="60" Margin="0,0,10,0"/>
            
            <Button Content="檢視紀錄" Command="{Binding ViewLogsCommand}" Width="80" Margin="0,0,10,0"/>
            <Button Content="刪除" Command="{Binding DeleteJobCommand}" Width="60" Background="#FFFFDDDD"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Jobs}" SelectedItem="{Binding SelectedJob}"
                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                  AlternatingRowBackground="#FFF0F0F0" RowHeight="30" FontSize="14"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                  
            <!-- 新增右鍵選單與雙擊事件支援 -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" />
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <MenuItem Header="執行(R)" Command="{Binding PlacementTarget.Tag.RunJobCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                          Visibility="{Binding PlacementTarget.DataContext.IsActiveState, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}" />
                                <MenuItem Header="結束(E)" Command="{Binding PlacementTarget.Tag.EndJobCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                          Visibility="{Binding PlacementTarget.DataContext.IsActiveState, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}" />
                                <MenuItem Header="停用(I)" Command="{Binding PlacementTarget.Tag.DisableJobCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                          Visibility="{Binding PlacementTarget.DataContext.IsActiveState, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}" />
                                
                                <MenuItem Header="啟用(N)" Command="{Binding PlacementTarget.Tag.EnableJobCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                          Visibility="{Binding PlacementTarget.DataContext.IsDisabledState, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BoolToVis}}" />
                                
                                <MenuItem Header="匯出(X)..." IsEnabled="False" />
                                <MenuItem Header="內容(P)" Command="{Binding PlacementTarget.Tag.EditJobCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="刪除(D)" Command="{Binding PlacementTarget.Tag.DeleteJobCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                    <EventSetter Event="MouseDoubleClick" Handler="DataGridRow_MouseDoubleClick" />
                </Style>
            </DataGrid.RowStyle>
            
            <DataGrid.Columns>
                <!-- 對齊 Windows 工作排程器的欄位順序 -->
                <DataGridTextColumn Header="名稱" Binding="{Binding JobName}" Width="150"/>
                <DataGridTextColumn Header="狀態" Binding="{Binding State}" Width="80"/>
                <DataGridTextColumn Header="觸發程序" Binding="{Binding TriggerDescription}" Width="350"/>
                <DataGridTextColumn Header="下次執行時間" Binding="{Binding NextFireTime, StringFormat=\{0:yyyy/MM/dd tt hh:mm:ss\}, TargetNullValue='無'}" Width="180"/>
                <DataGridTextColumn Header="上次執行時間" Binding="{Binding PreviousFireTime, StringFormat=\{0:yyyy/MM/dd tt hh:mm:ss\}, TargetNullValue='無'}" Width="200"/>
                
                <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding Jobs.Count, StringFormat=總任務數: \{0\}}" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding SelectedJob.JobName, StringFormat=已選擇: \{0\}, FallbackValue=未選擇任務}" Foreground="Gray" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
