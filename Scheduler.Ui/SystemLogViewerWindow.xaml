<ui:FluentWindow x:Class="Scheduler.Ui.SystemLogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="系統管理與稽核紀錄" Height="600" Width="1100"
        WindowStartupLocation="CenterOwner" Loaded="Window_Loaded"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica" WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="系統管理與稽核紀錄" />
        
        <Grid Grid.Row="1" Margin="20,0,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Margin="0,0,0,10" Orientation="Horizontal">
            <TextBlock Text="📁" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="Gray"/>
            <TextBlock x:Name="LogCountText" VerticalAlignment="Center" FontSize="14"/>
        </StackPanel>
        
        <DataGrid Grid.Row="1" x:Name="LogsGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                  RowHeight="26" GridLinesVisibility="Horizontal" HeadersVisibility="Column" BorderThickness="0" Background="Transparent">
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Resources>
                <Style x:Key="CellTextStyle" TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="HorizontalAlignment" Value="Left"/>
                    <Setter Property="Margin" Value="10,0,10,0"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#E3F2FD" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="類型" Binding="{Binding LevelIcon}" Width="120" ElementStyle="{StaticResource CellTextStyle}"/>
                <DataGridTextColumn Header="觸發時間" Binding="{Binding EventTime}" Width="190" ElementStyle="{StaticResource CellTextStyle}"/>
                <DataGridTextColumn Header="事件 ID" Binding="{Binding Original.EventId}" Width="90" ElementStyle="{StaticResource CellTextStyle}"/>
                <DataGridTextColumn Header="操作分類" Binding="{Binding Category}" Width="220" ElementStyle="{StaticResource CellTextStyle}"/>
                <DataGridTextColumn Header="影響目標 (群組.名稱)" Binding="{Binding Target}" Width="280" ElementStyle="{StaticResource CellTextStyle}"/>
                <DataGridTextColumn Header="操作人員" Binding="{Binding Original.AccountName}" Width="*" Foreground="Gray" ElementStyle="{StaticResource CellTextStyle}"/>
            </DataGrid.Columns>
        </DataGrid>

        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="#E0E0E0" Margin="0,5"/>

        <GroupBox Grid.Row="3" Header="{Binding SelectedItem.Original.EventId, ElementName=LogsGrid, StringFormat='事件 \{0\} 詳細資訊', TargetNullValue='(未選取事件)'}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="5">
                <TextBlock Text="{Binding SelectedItem.Original.Description, ElementName=LogsGrid}" TextWrapping="Wrap" Margin="10,10,10,20" FontSize="14"/>
            </ScrollViewer>
        </GroupBox>
        </Grid>
    </Grid>
</ui:FluentWindow>
